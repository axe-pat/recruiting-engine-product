{
  "manifest_version": 3,
  "name": "Recruiting Engine Companion",
  "short_name": "RE Companion",
  "version": "1.0.0",
  "description": "Review page context and hand it to a local Recruiting Engine companion without scraping or sending messages.",
  "homepage_url": "https://axe-pat.github.io/",
  "minimum_chrome_version": "116",
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "storage"
  ],
  "optional_host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open Recruiting Engine Companion",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
