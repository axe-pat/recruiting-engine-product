{
  "name": "recruiting-engine-product",
  "version": "1.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "export:static": "npm run build && node scripts/export-static.mjs",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run test:web && npm run test:companion && npm run test:extension",
    "test:web": "npm run verify:privacy && npm run build && node --test tests/*.test.mjs",
    "test:companion": "PYTHONPATH=companion python3 -m unittest discover -s companion/tests -v",
    "test:extension": "node --test extension/tests/*.test.mjs && node --check extension/service-worker.js && node --check extension/sidepanel.js && node --check extension/lib/contract.js",
    "verify:privacy": "node scripts/verify-public-boundary.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern static-export"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.14"
    }
  },
  "type": "module"
}
